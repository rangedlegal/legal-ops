generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                String    @default("TEAM_MEMBER")
  active              Boolean   @default(true)
  jobTitle            String?
  costRate            Float?
  capacityUnits       Int       @default(120)
  seniorityMultiplier Float     @default(1.0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clientsOwned  Client[]             @relation("AccountOwner")
  assignedTasks Task[]               @relation("AssignedTo")
  reviewedTasks Task[]               @relation("Reviewer")
  reports       Report[]
  capacities    TeamMemberCapacity[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id                     String   @id @default(cuid())
  name                   String
  subscriptionTier       String
  monthlyFee             Float
  billingStartDate       DateTime
  accountOwnerId         String
  status                 String   @default("ACTIVE")
  includedScope          String?
  excludedScope          String?
  monthlyEffortAllowance Int?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  accountOwner User     @relation("AccountOwner", fields: [accountOwnerId], references: [id])
  tasks        Task[]
  reports      Report[]
}

model Task {
  id                  String    @id @default(cuid())
  clientId            String
  title               String
  description         String?
  category            String
  assignedToId        String?
  reviewerId          String?
  status              String    @default("NEW")
  priority            String    @default("NORMAL")
  complexity          String    @default("MEDIUM")
  effortScore         Float     @default(3)
  seniorityMultiplier Float     @default(1.0)
  urgencyMultiplier   Float     @default(1.0)
  weightedEffortUnits Float     @default(3)
  dueDate             DateTime?
  completedAt         DateTime?
  intakeSource        String    @default("MANUAL")
  outOfScope          Boolean   @default(false)
  internalNotes       String?
  clientFacingSummary String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client     Client @relation(fields: [clientId], references: [id])
  assignedTo User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  reviewer   User?  @relation("Reviewer", fields: [reviewerId], references: [id])
}

model TeamMemberCapacity {
  id            String   @id @default(cuid())
  userId        String
  month         Int
  year          Int
  capacityUnits Int      @default(120)
  costPerUnit   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model FirmSettings {
  id                    String   @id @default(cuid())
  blendedCostPerUnit    Float    @default(50)
  adminUpliftPercentage Float    @default(10)
  overheadPercentage    Float    @default(8)
  defaultCurrency       String   @default("AUD")
  firmName              String   @default("Legal Firm")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Report {
  id             String   @id @default(cuid())
  clientId       String
  month          Int
  year           Int
  reportTitle    String
  generatedById  String
  pdfPath        String?
  reportDataJson String?
  createdAt      DateTime @default(now())

  client      Client @relation(fields: [clientId], references: [id])
  generatedBy User   @relation(fields: [generatedById], references: [id])
}
